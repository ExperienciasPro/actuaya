# MongoDB — Conexión local (misma máquina VPS)
# Si MongoDB requiere autenticación, usar: mongodb://usuario:password@127.0.0.1:27017/actuaya_db?authSource=admin
MONGODB_URI=mongodb://127.0.0.1:27017/actuaya_db

# Database name
DB_NAME=actuaya_db

# Auth token (matches Angular frontend)
AUTH_TOKEN=cada38hydf

# CORS origin
CORS_ORIGIN=https://actuaya.co

# Port
PORT=3002

# SMTP — Email transaccional (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=recuperacion@actuaya.co
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM="ActuaYa" <recuperacion@actuaya.co>

# Frontend URL (para construir links de reset)
FRONTEND_URL=https://www.actuaya.co
